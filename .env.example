# Copy this file to .env.local for local development, and set the same
# variables in your hosting provider (e.g. Cloudflare Pages) for production.

# Public base URL of the site, used for canonical links, sitemap, robots,
# Open Graph URLs, and share/OG image links. No trailing slash.
# Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://test-tier.com

# Operator contact email shown on the Contact, Privacy, and Terms pages.
# Required before applying for ad review (Google AdSense / Kakao AdFit).
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# Google Analytics 4 measurement ID (starts with G-). Optional: analytics
# only loads when this is set. Create a GA4 property to get it.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cloudflare Turnstile (bot protection on leaderboard submit). Optional:
# the Turnstile widget + server verification only activate when both are set.
# - Site key is public (build variable).
# - Secret key is server-only: set it as a Cloudflare *runtime* secret
#   (Settings > Variables and Secrets, or `wrangler secret put TURNSTILE_SECRET_KEY`),
#   NOT a build variable.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
